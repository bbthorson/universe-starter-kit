{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "example.universe.scene",
  "$comment": "Internal record schema. Placeholder NSID root (ARCHITECTURE.md §5). One record per chapter, from chapter frontmatter. The spine of any timeline view (§6).",
  "title": "scene",
  "type": "object",
  "required": ["$type", "id", "storyDate", "chapterRefs", "createdAt"],
  "additionalProperties": false,
  "properties": {
    "$type": {"const": "example.universe.scene"},
    "id": {"type": "string", "pattern": "^scene\\."},
    "storyDate": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "storyDateEnd": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "chapterRefs": {"type": "array", "items": {"type": "string"}},
    "title": {"type": ["string", "null"]},
    "part": {"type": ["integer", "string", "null"]},
    "beat": {"type": ["string", "null"]},
    "placeRefs": {"type": "array", "items": {"type": "string", "pattern": "^place\\."}},
    "placeText": {"type": ["array", "null"], "items": {"type": "string"}},
    "pov": {"type": ["string", "null"]},
    "participants": {"type": "array", "items": {"type": "string", "pattern": "^char\\."}},
    "referenced": {"type": "array", "items": {"type": "string", "pattern": "^char\\."}},
    "primaryEvent": {"type": ["string", "null"]},
    "createdAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "sourceFile": {"type": "string"}
  }
}
