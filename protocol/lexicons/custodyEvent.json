{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "example.universe.custodyEvent",
  "$comment": "Internal record schema. Placeholder NSID root (ARCHITECTURE.md §5). Reading an item's custodyEvent series ordered by storyDate reconstructs the literal path of the object (§6).",
  "title": "custodyEvent",
  "type": "object",
  "required": ["$type", "id", "item", "storyDate", "holder", "chapterRef", "createdAt"],
  "additionalProperties": false,
  "properties": {
    "$type": {"const": "example.universe.custodyEvent"},
    "id": {"type": "string", "pattern": "^custodyEvent\\."},
    "item": {"type": "string", "pattern": "^item\\."},
    "storyDate": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "holder": {"type": "string", "pattern": "^char\\."},
    "fromHolder": {"type": ["string", "null"], "pattern": "^char\\."},
    "chapterRef": {"type": "string"},
    "event": {"type": "string"},
    "createdAt": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
  }
}
